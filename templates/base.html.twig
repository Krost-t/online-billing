<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Mon App{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <nav id="sidebar" class="d-flex flex-column">
            <div class="sidebar-header text-center">
                <div class="d-flex align-items-center justify-content-center">
                    <div class="bg-success rounded-circle me-2" style="width: 30px; height: 30px;"></div>
                    <span> Lorem ipsum </span>
                </div>
            </div>

            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a href="#" class="nav-link active d-flex align-items-center">
                        <i class="bi bi-house-door-fill me-2"></i> Accueil
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-person-fill me-2"></i> Client
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-file-text-fill me-2"></i> Devis
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-receipt me-2"></i> Factures
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-cart-fill me-2"></i> Factures d’achats
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-journal-text me-2"></i> Note de frais
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-bar-chart-fill me-2"></i> Bilan comptable
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link d-flex align-items-center">
                        <i class="bi bi-gear-fill me-2"></i> Paramètres
                    </a>
                </li>
                <li class="nav-item mt-auto">
                    <a href="#" class="nav-link danger d-flex align-items-center">
                        <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                    </a>
                </li>
            </ul>
        </nav>

        <div class="flex-grow-1">
            <header id="header" class="d-flex">
                <div class="icon-bulb">💡</div>
                <div class="progress flex-grow-1 align-self-center" style="height: 6px; margin-right: 20px;">
                    <div class="progress-bar" role="progressbar" style="width: 60%;" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <form class="search-box d-flex align-items-center" role="search">
                    <input class="form-control form-control-sm" type="search" placeholder="Rechercher" aria-label="Rechercher">
                </form>
            </header>

            <main class="p-4">
                {% block body %}
                {# Contenu principal ici #}
                {% endblock %}
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.js"></script>
</body>
</html>

