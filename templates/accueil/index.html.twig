{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>
	<header>
		<div class="logo-place">
			<a href="{{ path('app_accueil') }}" title="Accueil">
				<img src="{{ asset('images/logo.png') }}" alt="Logo"/>
			</a>
		</div>
		<nav class="nav-place">
			<ul>
				<li><a href="{{ path('app_register') }}">Inscription</a></li>
				<li><a href="{{ path('app_login') }}">Connexion</a></li>
			</ul>
		</nav>
	</header>

	<main>
		<article class="welcome-article">
			<div>
				<h1>Bienvenue sur notre site !</h1>
				<p>Ce site est un exemple de page d'accueil utilisant Twig et Symfony.</p>
				<p>Vous pouvez naviguer vers les pages d'inscription et de connexion en utilisant le menu ci-dessus.</p>
				<p>Pour plus d'informations, consultez la
					<a href="https://symfony.com/doc/current/index.html">documentation Symfony</a>.</p>
			</div>
			<div class="img-article">
				<img src="{{ asset('images/welcome-image.jpg') }}" alt="Image de bienvenue"/>
			</div>

		</article>
	</main>

{% endblock %}
